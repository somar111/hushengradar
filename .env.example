# Supabase（必填）
# 项目 URL，可在 Supabase Dashboard → Project Settings → API 找到
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key（服务端专用，切勿暴露到前端或提交到 git）
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# DeepSeek（必填，用于分类、翻译、摘要、回复建议、综合分析、问 AI）
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# ── 以下仅 Cloudflare 本地预览 / wrangler 需要 ──
# 复制本文件为 .dev.vars（wrangler 会自动读取，已在 .gitignore 中）
# NEXT_PUBLIC_SUPABASE_URL 在 build 阶段注入，本地 preview 通常只需下面两个 secret
