flowchart TB
  classDef note fill:#35353c,stroke:#707080,stroke-width:1px,color:#d8d8dc

  NOTE_CTX["说明：单条分类前，每个 App 的上下文与噪声护栏。<br/>「命中 N 次」= 已有 N 条评论带该 subKey。"]
  class NOTE_CTX note

  subgraph block [分类准备 · 自上而下]
    direction TB

    SEED[seed_categories<br/>App 顶层标签体系]
    INTENT[intent 补全<br/>缺 intent 时一次性写回]
    POOL["子问题复用池<br/>历史高频 sub；命中 ≥5 且非本轮新造"]
    SUBS[universal_subcategories<br/>通用母类子问题]
    GSUB["母类已有 ≥2 个有效 sub<br/>才强制 subKey"]

    SEED --> INTENT --> POOL --> SUBS --> GSUB

    N3["taxonomy 信号<br/>命中量 + 跨 ≥3 天沉淀"]
    N4["低命中 ephemeral sub<br/>命中 ≤4 清零重标"]
    GSUB --> N3 --> N4

    OUT_PIPE["→ 单条分类管线<br/>初判输入"]
    OUT_EVO["→ 批后 taxonomy 演进"]
    OUT_RERUN["→ 清零后重回单条管线"]
    GSUB --> OUT_PIPE
    N3 --> OUT_EVO
    N4 --> OUT_RERUN
  end

  NOTE_CTX --> block
